<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> Server File Explorer | Home  </title>
    <link rel="stylesheet" href= "styles.css" />
</head>
<body>
    
    <center>
       
       
        <form action="/" method="post" enctype="multipart/form-data">
            
            <input type="file" name="submitedFile" class="submissionBox">
            <br>
            <input class="submit" type="submit" value="Submit">

        </form>
       

        <br>


        <div class="mainFiles">
            <% for(file of Files) { %>
                
                <p><%= file %></p> 
                <a href= "<%= file %>" download>
                    <button class="buttons">Download</button>
                </a>
                <button onclick="removeItem('<%= file %>')" class="buttons">Delete - Does not work</button>
 
            <% } %>    
        </div>

        

   
      

    </center>

   <h4><%= version %></h4>

</body>

<script type="text/javascript" src="remove.js"></script>

<script type="text/javascript">

    
    
    var Files = "<%= Files %>"
    var file = "<%= file %>"
    var array = Files.split(',')


    function removeItem(item) {
        var index = array.indexOf(item)
        //console.log(index)
        
        array.splice(index, 1)
        console.log(array)

        

    }
</script>




</html>